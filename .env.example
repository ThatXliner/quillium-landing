# Public Supabase configuration used by the hosted read-only share pages.
# These values are browser/server-render safe. Never put service-role keys here.
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# Supabase Auth URL Configuration for production:
# Site URL: https://quillium.bryanhu.com/auth
# Redirect URLs:
# - https://quillium.bryanhu.com/auth
# - https://quillium.bryanhu.com/auth/callback
# - https://quillium.bryanhu.com/auth/confirm
# - https://quillium.bryanhu.com/auth/reset-password
# Use https://quillium.bryanhu.com/auth/reset-password as the password recovery redirectTo.
# Default recovery links that land on /auth are also detected from the URL type/path.
# With this Site URL, token-hash templates should use {{ .SiteURL }}/confirm?...,
# not {{ .SiteURL }}/auth/confirm?... .

# Public analytics configuration.
PUBLIC_POSTHOG_PROJECT_TOKEN=your-posthog-project-token
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
