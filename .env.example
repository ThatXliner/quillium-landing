# Public Supabase configuration used by the hosted read-only share pages.
# These values are browser/server-render safe. Never put service-role keys here.
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# Public analytics configuration.
PUBLIC_POSTHOG_PROJECT_TOKEN=your-posthog-project-token
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
