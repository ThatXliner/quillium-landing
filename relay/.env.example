# Supabase configuration
# Get these from your Supabase project: Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server port
PORT=3001
HOST=0.0.0.0

# Comma-separated browser origins allowed to open WebSocket connections.
# Leave unset only for local testing.
ALLOWED_ORIGINS=http://localhost:5173,tauri://localhost,https://quillium.ai

# error, warn, info, or debug
LOG_LEVEL=info

# Batch high-frequency Yjs update persistence writes.
PERSIST_DEBOUNCE_MS=500
